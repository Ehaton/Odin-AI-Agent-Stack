# Odin environment configuration
#
# Copy this file to .env and fill in your values.
# NEVER commit the real .env — it's in .gitignore.

# ─── Core ──────────────────────────────────────────────────────────

# Ollama API endpoint (default: localhost)
OLLAMA_HOST=http://localhost:11434

# Web UI port
ODIN_PORT=5050

# Vault path on disk (filesystem mode). Alternative: set OBSIDIAN_API_KEY
# for the Obsidian REST API plugin instead.
ODIN_VAULT_PATH=/path/to/obsidian_vault

# Alternative: Obsidian Local REST API plugin
# OBSIDIAN_URL=http://127.0.0.1:27123
# OBSIDIAN_API_KEY=

# ─── Home Assistant (optional) ─────────────────────────────────────

# Long-lived access token from HA: Profile → Security → Long-Lived Tokens
HASS_URL=http://homeassistant.local:8123
HASS_TOKEN=

# ─── Proxmox VE API (optional) ─────────────────────────────────────

# Create at: Datacenter → Permissions → API Tokens
# Uncheck privilege separation, grant PVEAdmin on /
PVE_TOKEN_ID=user@pam!odin
PVE_TOKEN_SECRET=

# ─── ChromaDB (for vault RAG) ──────────────────────────────────────

CHROMADB_URL=http://localhost:8000
CHROMA_TOKEN=

# ─── SearXNG (for web search) ──────────────────────────────────────

SEARXNG_URL=http://localhost:8080

# ─── ComfyUI (for image generation) ────────────────────────────────

COMFYUI_URL=http://localhost:8188
ODIN_IMAGE_DIR=/opt/Odin/generated_images

# ─── Tailscale HTTPS (optional) ────────────────────────────────────

# If set, Odin will serve HTTPS using these certs
# TAILSCALE_CERT=/path/to/cert.crt
# TAILSCALE_KEY=/path/to/cert.key
