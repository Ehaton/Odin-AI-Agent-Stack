# Odin configuration — copy to .env and fill in your values
# NEVER commit .env to git (already in .gitignore)

# --- Required: Authentication ---
# Generate a strong password, e.g.: python -c "import secrets; print(secrets.token_urlsafe(24))"
ODIN_USER=INPUT_YOUR_USER
ODIN_PASS=INPUT_YOUR_PASSWORD

# --- Required: Ollama ---
OLLAMA_HOST=http://localhost:11434

# --- Optional: Obsidian knowledge base ---
# Enable the Local REST API plugin in Obsidian to get a key
OBSIDIAN_URL=http://YOUR_IP_HERE:27123
#ODIN_VAULT_PATH= #ONLY USE IF MOUNTED VIA SMB SHARE
OBSIDIAN_API_KEY=YOUR_OBSIDIAN_REST_API

# --- Optional: Network/deployment ---
ODIN_PORT=5050
ODIN_DB=odin.db
ODIN_HOSTS_FILE=hosts.json

# --- Optional: Tailscale HTTPS ---
# If set, Odin looks for {TAILNET_NAME}.crt and {TAILNET_NAME}.key in cwd
# Generate them with: tailscale cert your-machine.tailXXXX.ts.net
TAILNET_NAME=DEVICE_NAME_HERE
# --- Dev override (DO NOT USE IN PRODUCTION) ---
# Set to 1 only if you need to run without authentication (e.g. local testing)
# ODIN_ALLOW_NOAUTH=
CHROMA_TOKEN=YOUR_TOKEN_HERE

# SearXNG — only set if not using default localhost
SEARXNG_URL=http://localhost:8080

# Proxmox VE (you create this — see below)
PVE_TOKEN_ID=YOUR_TOKEN_HERE
PVE_TOKEN_SECRET=YOUR_TOKEN_SECRET

# Home Assistant (from HA Profile → Security → Long-Lived Tokens)
HASS_URL=http://YOUR_IP_HERE:8123
HASS_TOKEN=YOUR_TOKEN_HERE

# ComfyUI — only set if not using default localhost
COMFYUI_URL=http://localhost:8188
ODIN_IMAGE_DIR=YOUR_DATA_DIRECTORY
