FROM llama3.2:3b

PARAMETER temperature 0.0
PARAMETER top_p 0.9
PARAMETER num_ctx 2048
PARAMETER repeat_penalty 1.05
PARAMETER stop "User:"
PARAMETER stop "\n\n"

# The SYSTEM directive is kept minimal here. The build script (build-odin-models.sh)
# splices the full odin-router.system.md content in at build time.
# For manual builds, replace this SYSTEM block with the full prompt text.

SYSTEM """
[REPLACE WITH CONTENTS OF odin-router.system.md]
"""
